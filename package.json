{
	"name": "trainpedia",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"seed": "tsx scripts/seed/01-discover.ts && tsx scripts/seed/02-enrich.ts && tsx scripts/seed/03-media.ts && tsx scripts/seed/backfill-value-numeric.ts && tsx scripts/seed/backfill-total-built.ts && tsx scripts/seed/backfill-regions.ts && tsx scripts/seed/04-reclassify.ts && tsx scripts/seed/05-aliases.ts && tsx scripts/seed/06-fleet.ts && tsx scripts/seed/07-landmarks.ts && tsx scripts/seed/09-eras.ts && tsx scripts/seed/08-validate.ts",
		"seed:media": "tsx scripts/seed/03-media.ts",
		"validate": "tsx scripts/seed/08-validate.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-zoom": "^3.0.8",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prisma": "^6.19.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.2",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@fontsource-variable/fraunces": "^5.2.9",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/hammersmith-one": "^5.2.8",
		"@prisma/client": "^6.19.3",
		"cheerio": "^1.2.0",
		"d3-scale": "^4.0.2",
		"d3-zoom": "^3.0.0",
		"gsap": "^3.15.0",
		"sharp": "^0.35.3",
		"zod": "^4.4.3"
	}
}
