// Trainpedia datamodel — UDKAST til CHECK-IN C1 (kør IKKE migrate før Ronnis godkendelse)
// Princip: strict factuality — alle fakta-bærende felter er nullable og ledsages af provenance.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Traction {
  STEAM
  DIESEL
  ELECTRIC
  OTHER // fx gas turbine (GT3), battery — findes i randen af historien
}

enum MediaKind {
  PHOTO
  BLUEPRINT
  DIAGRAM
  DOCUMENT
  VIDEO
}

/// Navneskema for en klasses aliasser (F5.2/F5.6/U3) — styrer visning + søgning.
enum AliasScheme {
  TOPS // "Class 37" — default visning (Ronni tænker i TOPS)
  PRE_TOPS // "D6700"
  BUILDER // "English Electric Type 3"
  NICKNAME // "Tractor"
  ORIGINAL // oprindeligt selskabsnavn/nummer før nationalisering, hvor forskelligt fra PRE_TOPS
}

/// De historiske æraer (Pre-Grouping → Modern Post-Privatisation)
model Era {
  id          Int               @id @default(autoincrement())
  slug        String            @unique // "big-four"
  name        String // "The Big Four"
  startYear   Int
  endYear     Int? // null = løbende (Modern)
  narrative   String? // kildeciteret æra-fortælling
  sortIndex   Int
  classes     LocomotiveClass[]
  sourceUrl   String?
  sourceRevision String?
  retrievedAt DateTime?
}

/// En lokomotivklasse — timeline-node. Positioneres efter serviceEntry.
model LocomotiveClass {
  id               Int             @id @default(autoincrement())
  wikidataQid      String          @unique // upsert-nøgle, fx "Q1131502" (Class 55)
  wikipediaTitle   String? // fx "British Rail Class 55"
  name             String // "Class 55"
  nickname         String? // "Deltic"
  traction         Traction
  wheelArrangement String? // "Co-Co", "4-6-2" — filterakse
  serviceEntry     DateTime? // faktisk indsættelsesdato (timeline-position)
  serviceExit      DateTime?
  buildStart       Int?
  buildEnd         Int?
  totalBuilt       Int?
  narrative        String? // "hvorfor klassen betød noget" — citeret fra kilde
  isLandmark       Boolean         @default(false) // F5.5: ring-station på kortet (fx A3, Deltic, Class 37, APT)
  powerType        String? // F11-D1: BTC Type 1–5 / "SHUNTER" / null — afledt af kildet hk-værdi i 04-reclassify.ts
  builder          String? // F11-D2: normaliseret fabrikant-nøgle (alias-tabel i kode, rå streng bevares i Specification)
  regions          String[]        @default([]) // BR-region(er) (F5.4-pivot): "WESTERN"/"EASTERN"/"MIDLAND"/"SOUTHERN"/"SCOTTISH". Flere = interchange på kortet. Eneste kilde til linjefarve (tractionColor) og kort-tilhørsforhold — traction-feltet ovenfor er nu altid DIESEL og bærer INGEN linje-betydning.
  era              Era             @relation(fields: [eraId], references: [id])
  eraId            Int
  specs            Specification[]
  media            MediaAsset[]
  aliases          ClassAlias[]
  locomotives      Locomotive[]
  narratives       NarrativeSection[]
  videos           VideoLink[]
  sourceUrl        String? // Wikipedia-artikel
  sourceRevision   String? // revisions-id for citatets version
  retrievedAt      DateTime?

  @@index([eraId, serviceEntry])
  @@index([traction])
  @@index([wheelArrangement])
}

/// Alternative navne/numre for en klasse (Wikidata skos:altLabel, pre-TOPS-numre,
/// byggerbetegnelser, kaldenavne) — bærer navneskema-vælgeren (F5.6/U3) og gør
/// søgningen alias-komplet (D6700, "Tractor" og "Class 37" finder samme klasse).
model ClassAlias {
  id          Int             @id @default(autoincrement())
  class       LocomotiveClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     Int
  alias       String // "D6700", "English Electric Type 3", "Tractor"
  scheme      AliasScheme
  fromYear    Int?
  toYear      Int?
  sourceUrl   String?
  retrievedAt DateTime?

  @@unique([classId, alias])
  @@index([alias])
}

enum LocoStatus {
  IN_SERVICE
  STORED
  PRESERVED
  SCRAPPED
  EXPORTED
  UNKNOWN
}

/// Et individuelt bygget lokomotiv (F6 "Opslagsværket") — fx 37403 "Isle of Mull".
model Locomotive {
  id             Int                  @id @default(autoincrement())
  class          LocomotiveClass      @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId        Int
  currentNumber  String // "37403"
  currentName    String? // "Isle of Mull"
  nicknames      String[]             @default([])
  status         LocoStatus           @default(UNKNOWN)
  location       String? // bevaringssted/operatør hvis kendt
  history        String? // individ-narrativ — citeret, strict factuality
  identities     LocomotiveIdentity[]
  sourceUrl      String?
  sourceRevision String? // revisions-id for citatets version
  retrievedAt    DateTime?

  @@unique([classId, currentNumber])
  @@index([status])
}

/// Omlitrerings-/navnehistorik pr. individ: D6607 -> 37307 -> 37403 "Isle of Mull".
/// Søgning finder individet uanset hvilket historisk nummer man kender.
model LocomotiveIdentity {
  id             Int        @id @default(autoincrement())
  loco           Locomotive @relation(fields: [locoId], references: [id], onDelete: Cascade)
  locoId         Int
  number         String
  name           String?
  fromYear       Int?
  toYear         Int?
  sortIndex      Int        @default(0)
  sourceUrl      String?
  sourceRevision String? // revisions-id for citatets version
  retrievedAt    DateTime?

  @@index([number])
}

/// Fleksibelt spec-grid (Manufacturer, Designer, Power Output, Tractive Effort, Top Speed, ...)
model Specification {
  id           Int             @id @default(autoincrement())
  class        LocomotiveClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId      Int
  key          String // "Power Output"
  value        String // "1.750 hp" — string bevarer kildens præcision/enheder
  unit         String? // normaliseret enhed hvis parsebar (til evt. sammenligninger)
  valueNumeric Float? // F9.15: parsede tal for sortering/scatterplot (undgår runtime-regex)
  sortIndex    Int             @default(0)
  sourceUrl    String?
  retrievedAt  DateTime?

  @@unique([classId, key])
}

/// Medie-asset fra Wikimedia Commons — downloadet lokalt, attribution er JURIDISK påkrævet ved CC-BY/SA
model MediaAsset {
  id          Int             @id @default(autoincrement())
  class       LocomotiveClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     Int
  kind        MediaKind
  localPath   String // "data/media/class-55/xxxx-960.webp" (basename; srcset-varianter afledes)
  width       Int
  height      Int
  title       String? // asset-titel til inspect-view
  year        Int? // fotografiets årstal (fra Commons-metadata — ellers null)
  locoNumber  String? // "37001" hvis identificérbart i metadata
  anecdote    String? // historisk kontekst — KUN fra kildens beskrivelse
  commonsUrl  String          @unique // kilde + dedup-nøgle
  license     String // "CC BY-SA 4.0", "Public domain"
  attribution String? // fotografkreditering (krav ved CC-BY/SA)
  sortIndex   Int             @default(0)
  retrievedAt DateTime

  @@index([classId, kind])
}

/// Sektioneret narrativ til dybdegående museumsviden (F12.3)
model NarrativeSection {
  id           Int             @id @default(autoincrement())
  class        LocomotiveClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId      Int
  title        String // f.eks. "Design & construction", "Operations", "Withdrawal", "Preservation"
  content      String // sektionens markdown-indhold
  sortIndex    Int             @default(0)
  sourceUrl    String?
  retrievedAt  DateTime?

  @@unique([classId, title])
}

/// Eksterne eller interne videolinks for en klasse (F12.5)
model VideoLink {
  id           Int             @id @default(autoincrement())
  class        LocomotiveClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId      Int
  title        String // f.eks. "Class 55 Deltic at Doncaster"
  youtubeId    String // YouTube video ID eller Commons video URL / id
  duration     String? // f.eks. "10:15"
  sortIndex    Int             @default(0)
  sourceUrl    String?
  retrievedAt  DateTime?

  @@unique([classId, youtubeId])
}
